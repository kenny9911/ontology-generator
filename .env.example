# ─────────────────────────────────────────────────────────────────────────────
# Ontology Generator — environment configuration
# Copy to `.env` and fill in. The ONLY required value is an LLM API key.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=                  # default LLM provider (https://openrouter.ai/keys)

# ── LLM model / provider (optional) ──────────────────────────────────────────
ONTOLOGY_GEN_MODEL=                  # e.g. google/gemini-2.5-pro (falls back to LLM_MODEL)
LLM_MODEL=                           # app-wide default model
LLM_PROVIDER=openrouter              # openrouter | openai | deepseek | qwen | moonshot
                                     # NOTE: `google` has no direct branch -> routes via OpenRouter
SITE_URL=http://localhost:3598       # cosmetic: OpenRouter HTTP-Referer header

# ── Storage (optional; defaults to an on-disk file store) ────────────────────
ONTOLOGY_GEN_STORE=file              # file | memory (unset => Supabase if configured, else file)
ONTOLOGY_GEN_DATA_DIR=               # default: <cwd>/.data/ontology-gen
#  ⚠ The file store needs a writable, persistent filesystem. It does NOT persist
#    on Vercel's read-only serverless FS — use Supabase there, or deploy as a
#    persistent Node process / container.

# ── Auth (optional; OFF by default = anonymous guest) ────────────────────────
ONTOLOGY_GEN_REQUIRE_AUTH=           # set to 1 to require a valid Bearer JWT
JWT_SECRET=                          # required only if you enable auth (no fallback)

# ── Supabase (optional upgrade: durable store) ───────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=                # service-role key

# ── Neo4j graph mirror (optional; ALL THREE required to enable) ──────────────
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ── Hyper-automation (optional) ──────────────────────────────────────────────
ONTOLOGY_GEN_COVERAGE_TARGET=        # 0..1, default 1.0 — document-coverage eval target
ONTOLOGY_GEN_ROUTER=                 # set 0 to disable the smart per-agent LLM router
#  Per-agent LLM overrides (uppercased agent id; beats settings + router):
#    ONTOLOGY_GEN_MODEL_<AGENT_ID>=     model for one agent
#    ONTOLOGY_GEN_PROVIDER_<AGENT_ID>=  provider for one agent
#  e.g. ONTOLOGY_GEN_MODEL_RULES_EXTRACTOR=openai/gpt-5

# ── Alternative provider keys (only if LLM_PROVIDER != openrouter) ───────────
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=
# QWEN_API_KEY=
# QWEN_BASE_URL=
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=
